# Cache-Control headers for Netlify
/*
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff
  Referrer-Policy: same-origin

# Caching for assets (Vite generates hashes for these)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Caching for images in public folder
/PrintsCartslogo.png
  Cache-Control: public, max-age=31536000, immutable
/favicon.png
  Cache-Control: public, max-age=31536000, immutable
/hero.jpeg
  Cache-Control: public, max-age=31536000, immutable
